{
  "ConnectionStrings": {
    "DefaultConnection": "Host=db;Port=5432;Database=clinicdb;Username=postgres;Password=postgres"
  },
  "JwtSettings": {
    "Secret": "MuitoSegredoParaTesteDeAgendaClinica2026",
    "Issuer": "ClinicApi",
